{
  "name": "Flutter Android Dev + Emulator",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.dart-code",
        "Dart-Code.flutter",
        "ms-vscode.cpptools",
        "ms-androidtools.vscode-android"
      ]
    }
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "remoteUser": "vscode",
  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": {
      "label": "Android Emulator (noVNC)",
      "onAutoForward": "notify"
    }
  }
}

